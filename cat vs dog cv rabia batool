ight)\n\nsizes = np.array(sizes)\nprint(\"Width  - min/mean/max:\", sizes[:,0].min(), sizes[:,0].mean(), sizes[:,0].max())\nprint(\"Height - min/mean/max:\", sizes[:,1].min(), sizes[:,1].mean(), sizes[:,1].max())\n\nplt.figure(figsize=(5,5))\nplt.scatter(sizes[:,0], sizes[:,1], alpha=0.3)\nplt.xlabel(\"Width\"); plt.ylabel(\"Height\")\nplt.title(\"Sampled image dimensions\")\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T03:48:36.405644Z","iopub.execute_input":"2026-07-15T03:48:36.405982Z","iopub.status.idle":"2026-07-15T03:48:41.210087Z","shell.execute_reply.started":"2026-07-15T03:48:36.405953Z","shell.execute_reply":"2026-07-15T03:48:41.20938Z"}},"outputs":[{"name":"stdout","text":"Width  - min/mean/max: 512 512.0 512\nHeight - min/mean/max: 512 512.0 512\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 500x500 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":31},{"id":"c440dcab-de0a-4309-b8c7-4158f7aa4e40","cell_type":"markdown","source":"## 4. Train / Validation / Test Split","metadata":{}},{"id":"f00a6d9f-f685-4987-bf8c-6fc59e433dc6","cell_type":"code","source":"IMG_SIZE = (160, 160)\nBATCH_SIZE = 32\n\ntrain_df, temp_df = train_test_split(df, test_size=0.3, stratify=df[\"label\"], random_state=SEED)\nval_df, test_df = train_test_split(temp_df, test_size=0.5, stratify=temp_df[\"label\"], random_state=SEED)\n\nprint(\"Train:\", len(train_df), \"Val:\", len(val_df), \"Test:\", len(test_df))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T03:48:48.741373Z","iopub.execute_input":"2026-07-15T03:48:48.742046Z","iopub.status.idle":"2026-07-15T03:48:48.754536Z","shell.execute_reply.started":"2026-07-15T03:48:48.742016Z","shell.execute_reply":"2026-07-15T03:48:48.753546Z"}},"outputs":[{"name":"stdout","text":"Train: 700 Val: 150 Test: 150\n","output_type":"stream"}],"execution_count":32},{"id":"08ab572d-f4c4-47db-b3a9-7985036872f6","cell_type":"markdown","source":"## 5. Data Pipelines (with Augmentation)\n\nWe build `tf.data` pipelines from the dataframes for efficient loading, and apply\naugmentation (flip, rotation, zoom, contrast) only to the training set.\n","metadata":{}},{"id":"46ba60bc-53d1-4529-875f-67bda4bb87c6","cell_type":"code","source":"def make_dataset(dataframe, img_size, batch_size, training=False):\n    label_map = {\"cat\": 0, \"dog\": 1}\n    filepaths = dataframe[\"filepath\"].values\n    labels = dataframe[\"label\"].map(label_map).values\n\n    ds = tf.data.Dataset.from_tensor_slices((filepaths, labels))\n\n    def load_img(path, label):\n        img = tf.io.read_file(path)\n        img = tf.image.decode_jpeg(img, channels=3)\n        img = tf.image.resize(img, img_size)\n        return img, label\n\n    ds = ds.map(load_img, num_parallel_calls=tf.data.AUTOTUNE)\n\n    if training:\n        ds = ds.shuffle(1000, seed=SEED)\n\n    ds = ds.batch(batch_size).prefetch(tf.data.AUTOTUNE)\n    return ds\n\ntrain_ds = make_dataset(train_df, IMG_SIZE, BATCH_SIZE, training=True)\nval_ds   = make_dataset(val_df,   IMG_SIZE, BATCH_SIZE)\ntest_ds  = make_dataset(test_df,  IMG_SIZE, BATCH_SIZE)\n\ndata_augmentation = keras.Sequential([\n    layers.RandomFlip(\"horizontal\"),\n    layers.RandomRotation(0.1),\n    layers.RandomZoom(0.1),\n    layers.RandomContrast(0.1),\n], name=\"augmentation\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T03:48:53.805955Z","iopub.execute_input":"2026-07-15T03:48:53.806576Z","iopub.status.idle":"2026-07-15T03:48:55.696861Z","shell.execute_reply.started":"2026-07-15T03:48:53.806547Z","shell.execute_reply":"2026-07-15T03:48:55.696245Z"}},"outputs":[{"name":"stderr","text":"WARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nI0000 00:00:1784087333.930499      58 gpu_device.cc:2020] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 15511 MB memory:  -> device: 0, name: Tesla P100-PCIE-16GB, pci bus id: 0000:00:04.0, compute capability: 6.0\n","output_type":"stream"}],"execution_count":33},{"id":"eff08c88-39e3-4d05-8b5c-4eb69eab6e74","cell_type":"code","source":"# Visualize what augmentation does to a sample image\nsample_img_path = train_df[\"filepath\"].iloc[0]\nimg = keras.utils.load_img(sample_img_path, target_size=IMG_SIZE)\nimg_arr = keras.utils.img_to_array(img)\nimg_batch = tf.expand_dims(img_arr, 0)\n\nplt.figure(figsize=(9,9))\nfor i in range(9):\n    augmented = data_augmentation(img_batch, training=True)\n    plt.subplot(3,3,i+1)\n    plt.imshow(augmented[0].numpy().astype(\"uint8\"))\n    plt.axis(\"off\")\nplt.suptitle(\"Augmentation examples on one image\")\nplt.tight_layout()\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T03:49:02.669762Z","iopub.execute_input":"2026-07-15T03:49:02.670608Z","iopub.status.idle":"2026-07-15T03:49:06.109214Z","shell.execute_reply.started":"2026-07-15T03:49:02.670578Z","shell.execute_reply":"2026-07-15T03:49:06.108041Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 900x900 with 9 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":34},{"id":"766e02d5-6da1-4522-aa82-b163780338fd","cell_type":"markdown","source":"## 6. Model 1 — Baseline CNN (from scratch)\n\nA simple convolutional network trained end-to-end, to establish a baseline before\nusing transfer learning.\n","metadata":{}},{"id":"d18fb6db-b0f6-4461-b559-240e020acd5d","cell_type":"code","source":"def build_baseline_cnn(input_shape):\n    inputs = keras.Input(shape=input_shape)\n    x = layers.Rescaling(1./255)(inputs)\n    x = data_augmentation(x)\n\n    for filters in [32, 64, 128, 128]:\n        x = layers.Conv2D(filters, 3, padding=\"same\", activation=\"relu\")(x)\n        x = layers.BatchNormalization()(x)\n        x = layers.MaxPooling2D()(x)\n\n    x = layers.GlobalAveragePooling2D()(x)\n    x = layers.Dropout(0.4)(x)\n    x = layers.Dense(64, activation=\"relu\")(