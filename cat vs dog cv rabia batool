\n    fig, axes = plt.subplots(1, 2, figsize=(8,4))\n    axes[0].imshow(arr.astype(\"uint8\")); axes[0].set_title(\"Original\"); axes[0].axis(\"off\")\n    axes[1].imshow(overlay); axes[1].set_title(\"Grad-CAM\"); axes[1].axis(\"off\")\n    plt.tight_layout(); plt.show()\n\nsample_path = test_df.sample(1, random_state=SEED)[\"filepath\"].values[0]\nshow_gradcam(sample_path, tl_model, base_model)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T03:52:23.153723Z","iopub.execute_input":"2026-07-15T03:52:23.154265Z","iopub.status.idle":"2026-07-15T03:52:23.727879Z","shell.execute_reply.started":"2026-07-15T03:52:23.154236Z","shell.execute_reply":"2026-07-15T03:52:23.727237Z"}},"outputs":[{"name":"stderr","text":"/tmp/ipykernel_58/2077938878.py:23: MatplotlibDeprecationWarning: The get_cmap function was deprecated in Matplotlib 3.7 and will be removed in 3.11. Use ``matplotlib.colormaps[name]`` or ``matplotlib.colormaps.get_cmap()`` or ``pyplot.get_cmap()`` instead.\n  jet = cm.get_cmap(\"jet\")(heatmap_resized)[..., :3]\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 800x400 with 2 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":44},{"id":"e43bd2e1-e5b2-4495-a5a2-3e45d5edcb4b","cell_type":"markdown","source":"## 11. Inference on a New Image","metadata":{}},{"id":"f5054197-1881-4e4d-8927-69bf1e9613b3","cell_type":"code","source":"def predict_image(filepath, model, img_size=IMG_SIZE, preprocess=preprocess_input):\n    img = keras.utils.load_img(filepath, target_size=img_size)\n    arr = keras.utils.img_to_array(img)\n    arr = preprocess(arr)\n    arr = np.expand_dims(arr, axis=0)\n    prob = model.predict(arr)[0][0]\n    label = \"dog\" if prob > 0.5 else \"cat\"\n    confidence = prob if prob > 0.5 else 1 - prob\n    plt.imshow(img)\n    plt.title(f\"Prediction: {label} ({confidence:.2%} confidence)\")\n    plt.axis(\"off\")\n    plt.show()\n    return label, confidence\n\n# Example — try i